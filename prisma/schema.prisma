generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id          Int      @id @default(autoincrement())
  email       String   @unique
  password    String
  accountType String   // admin | customer | brand
  createdAt   DateTime @default(now())
  name        String

  orders      Order[]
  cartItems   CartItem[]
  quotes      QuoteRequest[]
  chat        Chat?    @relation("UserChat")
  adminChats  Chat[]   @relation("AdminChats")
  sentMessages Message[]

  @@index([email])
}

model Product {
  id             Int      @id @default(autoincrement())
  name_en        String
  name_es        String
  description_en String?
  description_es String?
  category       String?
  price          Float
  stock          Int      @default(0)
  imageUrl       String?                  // primary image (kept for backwards compat)
  images         String                 // gallery: ordered array of image URLs
  sizes          String                 // e.g. ["XS","S","M","L","XL","XXL"]
  colors         String                   // e.g. [{ "name": "Ivory", "hex": "#f5f0e8" }]
  isDeleted      Boolean  @default(false)
  createdAt      DateTime @default(now())

  orderItems     OrderItem[]
  cartItems      CartItem[]

  @@index([category])
  @@index([name_en])
  @@index([isDeleted])
}


model CartItem {
  id        Int     @id @default(autoincrement())
  userId    Int
  productId Int
  quantity  Int

  user      User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([userId, productId])
}

model Order {
  id          Int      @id @default(autoincrement())
  userId      Int
  totalAmount Float
  createdAt   DateTime @default(now())

  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  orderItems  OrderItem[]

  @@index([userId])
}

model OrderItem {
  id        Int     @id @default(autoincrement())
  orderId   Int
  productId Int
  quantity  Int
  price     Float

  order     Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([orderId])
  @@index([productId])
}

model Chat {
  id        Int      @id @default(autoincrement())
  userId    Int      @unique
  adminId   Int
  createdAt DateTime @default(now())

  user      User     @relation("UserChat", fields: [userId], references: [id], onDelete: Cascade)
  admin     User     @relation("AdminChats", fields: [adminId], references: [id], onDelete: Cascade)
  messages  Message[]

  @@index([adminId])
}

model Message {
  id        Int      @id @default(autoincrement())
  chatId    Int
  senderId  Int
  text      String
  createdAt DateTime @default(now())

  chat      Chat     @relation(fields: [chatId], references: [id], onDelete: Cascade)
  sender    User     @relation(fields: [senderId], references: [id], onDelete: Cascade)

  @@index([chatId])
  @@index([senderId])
}

model QuoteRequest {
  id        Int      @id @default(autoincrement())

  brandName String
  email     String
  message   String

  // NEW FIELDS
  status    String
  adminResponse String?

  userId    Int
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
}